# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Supabase
# Backend uses the service-role key — never the anon key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref

# Apify (Module 4.7 social scraping)
APIFY_TOKEN=your-apify-token
APIFY_TIKTOK_ACTOR_ID=clockworks~tiktok-scraper
APIFY_IG_ACTOR_ID=apify~instagram-profile-scraper
APIFY_SNAP_ACTOR_ID=your-snapchat-actor-id

# Shared secret the cron Edge Function uses to call the API.
# Match this in the Edge Function env (`supabase secrets set SERVICE_TOKEN=...`).
SERVICE_TOKEN=change-me-to-a-long-random-string
